---
import BaseLayout from '@layouts/BaseLayout.astro';
import AgentDirectory from '@components/AgentDirectory.vue';
import SetupNotification from '@components/SetupNotification.vue';
---

<BaseLayout title="Agents">
  <div class="page-header">
    <div class="page-header-row">
      <div>
        <h1 class="page-title">Agents</h1>
        <p class="page-subtitle">AI agents across your campaigns.</p>
      </div>
    </div>
  </div>

  <SetupNotification context="agents" client:load />
  <AgentDirectory client:load />
</BaseLayout>
