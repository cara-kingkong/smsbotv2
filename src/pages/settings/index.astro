---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Settings">
  <div class="page-header">
    <h1>Settings</h1>
    <p>Workspace configuration and integrations</p>
  </div>

  <div class="card">
    <h2 style="font-size: 1.125rem; margin-bottom: 1rem;">Integrations</h2>

    <div style="display: grid; gap: 1rem;">
      <div style="display: flex; justify-content: space-between; align-items: center; padding: 1rem; background: var(--color-bg); border-radius: var(--radius);">
        <div>
          <strong>Twilio (SMS)</strong>
          <p style="color: var(--color-text-muted); font-size: 0.75rem;">Send and receive SMS messages</p>
        </div>
        <span style="color: var(--color-text-muted); font-size: 0.75rem;">Not configured</span>
      </div>

      <div style="display: flex; justify-content: space-between; align-items: center; padding: 1rem; background: var(--color-bg); border-radius: var(--radius);">
        <div>
          <strong>OpenAI</strong>
          <p style="color: var(--color-text-muted); font-size: 0.75rem;">AI-powered conversation replies</p>
        </div>
        <span style="color: var(--color-text-muted); font-size: 0.75rem;">Not configured</span>
      </div>

      <div style="display: flex; justify-content: space-between; align-items: center; padding: 1rem; background: var(--color-bg); border-radius: var(--radius);">
        <div>
          <strong>Anthropic</strong>
          <p style="color: var(--color-text-muted); font-size: 0.75rem;">Alternative AI provider</p>
        </div>
        <span style="color: var(--color-text-muted); font-size: 0.75rem;">Not configured</span>
      </div>

      <div style="display: flex; justify-content: space-between; align-items: center; padding: 1rem; background: var(--color-bg); border-radius: var(--radius);">
        <div>
          <strong>Calendly</strong>
          <p style="color: var(--color-text-muted); font-size: 0.75rem;">Calendar booking for qualified leads</p>
        </div>
        <span style="color: var(--color-text-muted); font-size: 0.75rem;">Not configured</span>
      </div>

      <div style="display: flex; justify-content: space-between; align-items: center; padding: 1rem; background: var(--color-bg); border-radius: var(--radius);">
        <div>
          <strong>Keap / Infusionsoft</strong>
          <p style="color: var(--color-text-muted); font-size: 0.75rem;">CRM outcome sync (tags, notes)</p>
        </div>
        <span style="color: var(--color-text-muted); font-size: 0.75rem;">Not configured</span>
      </div>
    </div>
  </div>
</BaseLayout>
