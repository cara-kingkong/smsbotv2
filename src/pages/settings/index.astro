---
import BaseLayout from '@layouts/BaseLayout.astro';

const integrations = [
  { name: 'Twilio (SMS)', desc: 'Send and receive SMS messages' },
  { name: 'OpenAI', desc: 'AI-powered conversation replies' },
  { name: 'Anthropic', desc: 'Alternative AI provider' },
  { name: 'Calendly', desc: 'Calendar booking for qualified leads' },
  { name: 'Keap / Infusionsoft', desc: 'CRM outcome sync (tags, notes)' },
];
---

<BaseLayout title="Settings">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold">Settings</h1>
    <p class="text-sm text-slate-400 mt-1">Workspace configuration and integrations</p>
  </div>

  <div class="bg-surface border border-slate-700 rounded-lg p-6">
    <h2 class="text-lg font-semibold mb-4">Integrations</h2>

    <div class="flex flex-col gap-3">
      {integrations.map(int => (
        <div class="flex justify-between items-center p-4 bg-slate-900 rounded-lg">
          <div>
            <div class="font-semibold text-sm">{int.name}</div>
            <div class="text-xs text-slate-400">{int.desc}</div>
          </div>
          <span class="text-xs text-slate-400">Not configured</span>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
