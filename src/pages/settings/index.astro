---
import BaseLayout from '@layouts/BaseLayout.astro';
import WorkspaceSettings from '@components/WorkspaceSettings.vue';
import IntegrationManager from '@components/IntegrationManager.vue';
---

<BaseLayout title="Settings">
  <div class="mb-6">
    <h1 class="text-2xl font-semibold">Settings</h1>
    <p class="text-sm text-slate-400 mt-1">Workspace configuration and integrations</p>
  </div>

  <div class="space-y-8">
    <section>
      <h2 class="text-lg font-semibold mb-4">Workspace Defaults</h2>
      <WorkspaceSettings client:load />
    </section>

    <section>
      <h2 class="text-lg font-semibold mb-4">Integrations</h2>
      <IntegrationManager client:load />
    </section>
  </div>
</BaseLayout>
