---
import BaseLayout from '@layouts/BaseLayout.astro';
import ActivityLog from '@components/ActivityLog.vue';
---

<BaseLayout title="Activity Log">
  <div class="page-header">
    <div class="page-header-row">
      <div>
        <p class="page-kicker">Operations</p>
        <h1 class="page-title">Activity Log</h1>
        <p class="page-subtitle">Audit trail of user and system actions across the workspace.</p>
      </div>
      <div class="page-badge">Audit history</div>
    </div>
  </div>

  <ActivityLog client:load />
</BaseLayout>
