---
import BaseLayout from '@layouts/BaseLayout.astro';
import JobQueue from '@components/JobQueue.vue';
---

<BaseLayout title="Job Queue">
  <div class="page-header">
    <div class="page-header-row">
      <div>
        <p class="page-kicker">Operations</p>
        <h1 class="page-title">Job Queue</h1>
        <p class="page-subtitle">Monitor pending, running, failed, and dead-lettered jobs.</p>
      </div>
      <div class="page-badge">Background processing</div>
    </div>
  </div>

  <JobQueue client:load />
</BaseLayout>
