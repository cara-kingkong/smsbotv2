---
import BaseLayout from '@layouts/BaseLayout.astro';
import WebhookViewer from '@components/WebhookViewer.vue';
---

<BaseLayout title="Webhook Receipts">
  <div class="page-header">
    <div class="page-header-row">
      <div>
        <p class="page-kicker">Operations</p>
        <h1 class="page-title">Webhook Receipts</h1>
        <p class="page-subtitle">View inbound webhook payloads and processing status.</p>
      </div>
      <div class="page-badge">Inbound event audit</div>
    </div>
  </div>

  <WebhookViewer client:load />
</BaseLayout>
