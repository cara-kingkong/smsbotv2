---
import BaseLayout from '@layouts/BaseLayout.astro';
import WebhookViewer from '@components/WebhookViewer.vue';
---

<BaseLayout title="Webhook Receipts">
  <div class="page-header">
    <div class="page-header-row">
      <div>
        <h1 class="page-title">Webhooks</h1>
        <p class="page-subtitle">Inbound webhook payloads and processing status.</p>
      </div>
    </div>
  </div>

  <WebhookViewer client:load />
</BaseLayout>
