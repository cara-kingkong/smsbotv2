---
import BaseLayout from '@layouts/BaseLayout.astro';
import CampaignManager from '@components/CampaignManager.vue';
import SetupNotification from '@components/SetupNotification.vue';
---

<BaseLayout title="Campaigns">
  <div class="page-header">
    <div class="page-header-row">
      <div>
        <h1 class="page-title">Campaigns</h1>
        <p class="page-subtitle">Manage campaign settings and agent assignments.</p>
      </div>
    </div>
  </div>

  <SetupNotification context="campaigns" client:load />
  <CampaignManager client:load />
</BaseLayout>
