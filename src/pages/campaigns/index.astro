---
import BaseLayout from '@layouts/BaseLayout.astro';
import CampaignManager from '@components/CampaignManager.vue';
---

<BaseLayout title="Campaigns">
  <div class="page-header">
    <div class="page-header-row">
      <div>
        <p class="page-kicker">Campaign Control</p>
        <h1 class="page-title">Campaigns</h1>
        <p class="page-subtitle">
          Create, tune, and review campaign settings with a cleaner split between list management and detailed configuration.
        </p>
      </div>
      <div class="page-badge">Workspace campaign library</div>
    </div>
  </div>

  <CampaignManager client:load />
</BaseLayout>
