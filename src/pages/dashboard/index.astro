---
import BaseLayout from '@layouts/BaseLayout.astro';
import DashboardView from '@components/DashboardView.vue';
---

<BaseLayout title="Dashboard">
  <div class="page-header">
    <div class="page-header-row">
      <div>
        <p class="page-kicker">Workspace Overview</p>
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">
          Track bookings, spot agent performance trends, and catch conversations that need human attention.
        </p>
      </div>
      <div class="page-badge">Live workspace metrics</div>
    </div>
  </div>

  <DashboardView client:load />
</BaseLayout>
