---
import { getPublicSupabaseConfig } from '@lib/config/public-server';
import '../styles/global.css';

// Middleware skips /login — check if already authenticated to redirect
const existingSession = (Astro.locals as Record<string, unknown>).session;
if (existingSession) return Astro.redirect('/dashboard');
const publicConfig = getPublicSupabaseConfig();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In | Kong SMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <script define:vars={{ publicConfig }}>
      window.__KONG_PUBLIC_CONFIG__ = publicConfig;
    </script>
  </head>
  <body>
    <main class="login-page">
      <div class="login-card">
        <div class="login-brand">KS</div>
        <h1 class="login-heading">Sign in to Kong SMS</h1>
        <p class="login-subtext">Use your Google account to continue.</p>

        <button class="button-primary w-full mt-6" id="google-signin">
          Continue with Google
        </button>
      </div>
    </main>

    <script>
      import { createClient } from '@supabase/supabase-js';
      import { getPublicSupabaseConfig } from '@lib/config/public-client';

      const { supabaseUrl, supabaseAnonKey } = getPublicSupabaseConfig();

      const supabase = createClient(supabaseUrl, supabaseAnonKey, {
        auth: {
          flowType: 'pkce',
          storage: window.localStorage,
          storageKey: 'sb-auth-token',
        },
      });

      function getAuthRedirectUrl() {
        return new URL('/auth/callback', window.location.origin).toString();
      }

      document.getElementById('google-signin')?.addEventListener('click', async () => {
        const { error } = await supabase.auth.signInWithOAuth({
          provider: 'google',
          options: {
            redirectTo: getAuthRedirectUrl(),
          },
        });
        if (error) console.error('Sign-in error:', error.message);
      });
    </script>
  </body>
</html>
