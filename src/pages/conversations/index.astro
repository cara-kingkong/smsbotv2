---
import BaseLayout from '@layouts/BaseLayout.astro';
import ConversationInbox from '@components/ConversationInbox.vue';
import SetupNotification from '@components/SetupNotification.vue';
---

<BaseLayout title="Conversations">
  <div class="page-header">
    <div class="page-header-row">
      <div>
        <h1 class="page-title">Conversations</h1>
        <p class="page-subtitle">Review and manage lead threads.</p>
      </div>
    </div>
  </div>

  <SetupNotification context="conversations" client:load />
  <ConversationInbox client:load />
</BaseLayout>
