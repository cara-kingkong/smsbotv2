---
import BaseLayout from '@layouts/BaseLayout.astro';
import ConversationInbox from '@components/ConversationInbox.vue';
import SetupNotification from '@components/SetupNotification.vue';
---

<BaseLayout title="Conversations">
  <div class="page-header">
    <div class="page-header-row">
      <div>
        <p class="page-kicker">Inbox</p>
        <h1 class="page-title">Conversations</h1>
        <p class="page-subtitle">
          Review lead threads, hand conversations back to AI when appropriate, and jump into replies without losing context.
        </p>
      </div>
      <div class="page-badge">Shared workspace inbox</div>
    </div>
  </div>

  <SetupNotification context="conversations" client:load />
  <ConversationInbox client:load />
</BaseLayout>
