---
import type { AuthSession } from '@lib/auth/middleware';
import { ensureWorkspace } from '@lib/auth/ensure-workspace';
import { getPublicSupabaseConfig } from '@lib/config/public-server';
import { getServiceClient } from '@lib/db/client';

interface Props {
  title: string;
}

// Session is guaranteed by middleware — all non-public routes are authenticated
const session = (Astro.locals as Record<string, unknown>).session as AuthSession;
const workspaceId = await ensureWorkspace(session);

// Fetch user display name and workspace name for the sidebar
const db = getServiceClient();
const { data: userRow } = await db
  .from('users')
  .select('full_name')
  .eq('id', session.user_id)
  .single();

const { data: workspaceRow } = await db
  .from('workspaces')
  .select('name')
  .eq('id', workspaceId)
  .single();

const userName = userRow?.full_name || session.email.split('@')[0];
const workspaceName = workspaceRow?.name || 'Workspace';

const publicConfig = getPublicSupabaseConfig({
  workspaceId,
  userId: session.user_id,
  userEmail: session.email,
  userName,
});

const currentPath = Astro.url.pathname;

const mainNav = [
  { href: '/dashboard', label: 'Dashboard' },
  { href: '/campaigns', label: 'Campaigns' },
  { href: '/conversations', label: 'Conversations' },
];

const adminNav = [
  { href: '/admin/leads', label: 'Leads' },
  { href: '/admin/webhooks', label: 'Webhooks' },
  { href: '/admin/jobs', label: 'Job Queue' },
  { href: '/admin/activity', label: 'Activity Log' },
];

const bottomNav = [
  { href: '/settings', label: 'Settings' },
];

const userInitial = userName.charAt(0).toUpperCase();
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kong SMS</title>
    <script define:vars={{ publicConfig }}>
      window.__KONG_PUBLIC_CONFIG__ = publicConfig;
    </script>
    <style>
      @import "../styles/global.css";
    </style>
  </head>
  <body class="bg-slate-900 text-slate-100 font-sans min-h-screen">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="w-60 bg-surface border-r border-slate-700 flex flex-col shrink-0">
        <div class="px-6 py-5 border-b border-slate-700 text-xl font-bold text-blue-500">
          Kong SMS
        </div>
        <nav class="flex-1 py-4 flex flex-col">
          <!-- Main navigation -->
          {mainNav.map(link => (
            <a
              href={link.href}
              class:list={[
                'block px-6 py-2.5 text-sm transition-colors',
                currentPath.startsWith(link.href)
                  ? 'text-slate-100 bg-surface-hover font-medium'
                  : 'text-slate-400 hover:text-slate-200 hover:bg-surface-hover',
              ]}
            >
              {link.label}
            </a>
          ))}

          <!-- Admin section -->
          <div class="mt-6 mb-1 px-6">
            <span class="text-[10px] uppercase tracking-widest text-slate-500 font-semibold">Admin</span>
          </div>
          {adminNav.map(link => (
            <a
              href={link.href}
              class:list={[
                'block px-6 py-2.5 text-sm transition-colors',
                currentPath.startsWith(link.href)
                  ? 'text-slate-100 bg-surface-hover font-medium'
                  : 'text-slate-400 hover:text-slate-200 hover:bg-surface-hover',
              ]}
            >
              {link.label}
            </a>
          ))}

          <!-- Spacer -->
          <div class="flex-1"></div>

          <!-- Bottom nav -->
          <div class="border-t border-slate-700 pt-2">
            {bottomNav.map(link => (
              <a
                href={link.href}
                class:list={[
                  'block px-6 py-2.5 text-sm transition-colors',
                  currentPath.startsWith(link.href)
                    ? 'text-slate-100 bg-surface-hover font-medium'
                    : 'text-slate-400 hover:text-slate-200 hover:bg-surface-hover',
                ]}
              >
                {link.label}
              </a>
            ))}
          </div>

          <!-- User / Workspace context -->
          <div class="border-t border-slate-700 px-4 py-3">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-blue-500/20 flex items-center justify-center text-blue-400 font-semibold text-sm shrink-0">
                {userInitial}
              </div>
              <div class="min-w-0">
                <div class="text-sm font-medium text-slate-200 truncate">{userName}</div>
                <div class="text-[11px] text-slate-500 truncate">{workspaceName}</div>
              </div>
            </div>
            <a
              href="/auth/logout"
              class="block mt-2 text-[11px] text-slate-500 hover:text-slate-300 transition-colors"
            >
              Sign out
            </a>
          </div>
        </nav>
      </aside>

      <!-- Main content -->
      <main class="flex-1 p-8 overflow-y-auto">
        <slot />
      </main>
    </div>
  </body>
</html>
