---
import type { AuthSession } from '@lib/auth/middleware';
import { resolveWorkspaceContext } from '@lib/auth/ensure-workspace';
import { getPublicSupabaseConfig } from '@lib/config/public-server';
import { getServiceClient } from '@lib/db/client';
import { computeOnboardingState } from '@lib/onboarding/service';
import type { OnboardingState } from '@lib/onboarding/service';
import WorkspaceSwitcher from '@components/WorkspaceSwitcher.vue';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props as Props;

// Session is guaranteed by middleware — all non-public routes are authenticated
const session = (Astro.locals as Record<string, unknown>).session as AuthSession;
const workspaceContext = await resolveWorkspaceContext(session, Astro);
const workspaceId = workspaceContext.activeWorkspaceId;

// Fetch user display name for the sidebar
const db = getServiceClient();
const { data: userRow } = await db
  .from('users')
  .select('full_name')
  .eq('id', session.user_id)
  .single();

const userName = userRow?.full_name || session.email.split('@')[0];
const activeWorkspace = workspaceContext.availableWorkspaces.find((ws) => ws.id === workspaceId);
const workspaceName = activeWorkspace?.name || 'Workspace';

let onboardingState: OnboardingState;
try {
  onboardingState = await computeOnboardingState(workspaceId);
} catch (err) {
  console.error('[onboarding] Failed to compute state:', err);
  // Fallback: assume activated so the app works normally if the query fails
  onboardingState = {
    hasCampaign: true,
    hasAgent: true,
    hasSmsProvider: true,
    hasCalendar: true,
    isActivated: true,
    currentStep: 5,
    completedSteps: 4,
  };
}

const publicConfig = getPublicSupabaseConfig({
  workspaceId,
  userId: session.user_id,
  userEmail: session.email,
  userName,
  activeWorkspaceRole: workspaceContext.activeRole,
  isPlatformAdmin: workspaceContext.isPlatformAdmin,
  availableWorkspaces: workspaceContext.availableWorkspaces,
});

const currentPath = Astro.url.pathname;

const mainNav = [
  { href: '/dashboard', label: 'Dashboard' },
  { href: '/campaigns', label: 'Campaigns' },
  { href: '/agents', label: 'Agents' },
  { href: '/calendar', label: 'Calendar' },
  { href: '/conversations', label: 'Conversations' },
];

const adminNav = onboardingState.isActivated ? [
  { href: '/admin/leads', label: 'Leads' },
  { href: '/admin/api-guide', label: 'API Guide' },
  { href: '/admin/webhooks', label: 'Webhooks' },
  { href: '/admin/jobs', label: 'Job Queue' },
  { href: '/admin/activity', label: 'Activity Log' },
] : [];

const platformNav = workspaceContext.isPlatformAdmin ? [
  { href: '/admin/workspaces', label: 'Workspaces' },
] : [];

const userInitial = userName.charAt(0).toUpperCase();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Kong SMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <script define:vars={{ publicConfig }}>
      window.__KONG_PUBLIC_CONFIG__ = publicConfig;
    </script>
    <script define:vars={{ onboardingState }}>
      window.__KONG_ONBOARDING__ = onboardingState;
    </script>
  </head>
  <body>
    <div class="app-layout">
      <!-- Top bar: logo + settings + user/workspace -->
      <header class="topbar">
        <div class="topbar-inner">
          <a href="/dashboard" class="topbar-brand">
            <div class="topbar-brand-mark">KS</div>
            <span class="topbar-brand-label">Kong SMS</span>
          </a>
          <div class="topbar-right">
            <WorkspaceSwitcher client:load />
            <a
              href="/settings"
              class:list={[
                'topbar-link',
                currentPath.startsWith('/settings') && 'topbar-link-active',
              ]}
            >
              Settings
            </a>
            <div class="topbar-divider"></div>
            <div class="topbar-user">
              <div class="topbar-user-avatar">{userInitial}</div>
              <div class="topbar-user-info">
                <div class="topbar-user-name">{userName}</div>
                <div class="topbar-user-workspace">{workspaceName}</div>
              </div>
            </div>
            <a href="/auth/logout" class="topbar-link topbar-link-signout">Sign out</a>
          </div>
        </div>
      </header>

      <div class="app-body">
        <div class="app-card">
          <!-- Left sidebar: nav links only -->
          <aside class="app-sidebar-slim">
            <nav class="flex flex-col h-full py-3 px-3">
              <div class="nav-group-slim">
                <div class="nav-label">Core</div>
                <div class="space-y-1">
                  {mainNav.map(link => {
                    const needsAttention = !onboardingState.isActivated && (
                      (link.href === '/campaigns' && !onboardingState.hasCampaign) ||
                      (link.href === '/agents' && !onboardingState.hasAgent) ||
                      (link.href === '/calendar' && !onboardingState.hasCalendar)
                    );
                    return (
                      <a
                        href={link.href}
                        class:list={[
                          'nav-link',
                          currentPath.startsWith(link.href) && 'nav-link-active',
                        ]}
                      >
                        <span>{link.label}</span>
                        {needsAttention ? (
                          <span class="nav-link-attention-dot"></span>
                        ) : (
                          <span class="nav-link-dot"></span>
                        )}
                      </a>
                    );
                  })}
                </div>
              </div>

              {adminNav.length > 0 && (
                <div class="nav-group-slim">
                  <div class="nav-label">Operations</div>
                  <div class="space-y-1">
                    {adminNav.map(link => (
                      <a href={link.href} class:list={['nav-link', currentPath.startsWith(link.href) && 'nav-link-active']}>
                        <span>{link.label}</span>
                        <span class="nav-link-dot"></span>
                      </a>
                    ))}
                  </div>
                </div>
              )}

              {platformNav.length > 0 && (
                <div class="nav-group-slim">
                  <div class="nav-label">Platform</div>
                  <div class="space-y-1">
                    {platformNav.map(link => (
                      <a href={link.href} class:list={['nav-link', currentPath.startsWith(link.href) && 'nav-link-active']}>
                        <span>{link.label}</span>
                        <span class="nav-link-dot"></span>
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </nav>
          </aside>

          <!-- Main content -->
          <main class="app-main">
            <div class="page-shell">
              <slot />
            </div>
          </main>
        </div>
      </div>
    </div>
  </body>
</html>
