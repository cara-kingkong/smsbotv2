    "astro": "^6.0.8",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "libphonenumber-js": "^1.12.40",
    "nanoid": "^5.1.7",
    "openai": "^6.32.0",
    "tailwindcss": "^4.2.2",
    "twilio": "^5.13.1",
    "vue": "^3.5.30",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@netlify/functions": "^5.1.5",
